%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#e8f4fd', 'primaryBorderColor': '#2196F3', 'secondaryColor': '#fff3e0', 'tertiaryColor': '#e8f5e9' } } }%%

graph TB
    subgraph kind["Kind Cluster (mcp-gateway)"]

        subgraph catalog-system["catalog-system namespace"]
            postgres[(PostgreSQL)]
            catalog-cm[/"ConfigMap<br/>mcp-catalog-sources"/]
            catalog-api["Catalog API<br/>(REST :8080)"]
            catalog-api --> postgres
            catalog-api --> catalog-cm
        end

        subgraph cert-manager-ns["cert-manager namespace"]
            selfsigned-issuer["ClusterIssuer<br/>selfsigned-issuer"]
            ca-cert["Certificate<br/>mcp-ca-cert (isCA)"]
            ca-secret["Secret<br/>mcp-ca-secret"]
            ca-issuer["ClusterIssuer<br/>mcp-ca-issuer"]
            selfsigned-issuer -->|signs| ca-cert
            ca-cert -->|stored in| ca-secret
            ca-secret -->|referenced by| ca-issuer
        end

        subgraph kuadrant-system["kuadrant-system namespace"]
            authorino["Authorino<br/>(auth engine)"]
            kuadrant-op["Kuadrant Operator"]
            limitador["Limitador<br/>(rate limiting)"]
        end

        subgraph keycloak-ns["keycloak namespace"]
            keycloak["Keycloak 26.3<br/>(OIDC provider :8080)"]
            realm-cm[/"ConfigMap<br/>realm-import"/]
            kc-svc["Service<br/>:80 → :8080"]
            keycloak --> realm-cm
            kc-svc --> keycloak
        end

        subgraph istio-system["istio-system namespace"]
            istiod["istiod<br/>(Gateway API controller)"]
            sail-operator["Sail Operator"]
        end

        subgraph mcp-system["mcp-system namespace"]
            mcp-ctrl["mcp-controller pod<br/>(cluster-wide CRD reconciler)"]
        end

        subgraph vault-ns["vault namespace"]
            vault-pod["Vault<br/>(dev mode :8200)"]
            vault-jwt-auth["JWT Auth Method<br/>(Keycloak JWKS)"]
            vault-role["Role: authorino<br/>(aud: mcp-gateway)"]
            vault-policy["Policy: authorino<br/>(read secret/data/mcp-gateway/*)"]
            vault-secrets[("Per-user secrets<br/>secret/mcp-gateway/{sub}")]
            vault-pod --- vault-jwt-auth
            vault-pod --- vault-secrets
        end

        subgraph team-a["team-a namespace"]
            team-a-gw["Gateway CR<br/>(team-a-gateway)"]
            team-a-envoy["Envoy Proxy<br/>(auto-created by Istio)"]
            team-a-gw-ext["MCPGatewayExtension<br/>(team-a-gateway-extension)"]
            team-a-mcp-gw["mcp-gateway pod<br/>(broker + router,<br/>auto-created by controller)"]
            team-a-config-secret["Secret (config)<br/>(auto-created by controller)"]

            server-a1-pod["test-server-a1 pod<br/>(MCP server :9090)<br/>5 tools: add_tool, greet,<br/>headers, slow, time"]
            server-a1-svc["test-server-a1 Service"]
            server-a1-httproute["HTTPRoute<br/>(test-server-a1)<br/>(auto-created by operator)"]
            server-a1-reg["MCPServerRegistration<br/>(test-server-a1)<br/>(auto-created by operator)"]

            server-a2-pod["test-server-a2 pod<br/>(MCP server :9090)<br/>7 tools: auth1234, headers,<br/>hello_world, pour_chocolate_into_mold,<br/>set_time, slow, time"]
            server-a2-svc["test-server-a2 Service"]
            server-a2-httproute["HTTPRoute<br/>(test-server-a2)<br/>(auto-created by operator)"]
            server-a2-reg["MCPServerRegistration<br/>(test-server-a2)<br/>(auto-created by operator)"]

            server-a1-svc --> server-a1-pod
            server-a2-svc --> server-a2-pod
        end

        subgraph operator-system["mcp-lifecycle-operator-system namespace"]
            operator["Lifecycle Operator<br/>(main + gateway reconciler)"]
        end

        subgraph metallb-system["metallb-system namespace"]
            metallb["MetalLB<br/>(controller + speaker)"]
        end

        %% Control plane relationships
        istiod -.->|"programs via xDS"| team-a-envoy

        %% Controller watches registrations
        mcp-ctrl -.->|"watches"| server-a1-reg
        mcp-ctrl -.->|"watches"| server-a2-reg
        mcp-ctrl -->|"creates"| team-a-mcp-gw
        mcp-ctrl -->|"creates"| team-a-config-secret

        %% Operator creates resources
        operator -->|"creates"| server-a1-pod
        operator -->|"creates"| server-a1-svc
        operator -->|"creates"| server-a1-httproute
        operator -->|"creates"| server-a1-reg
        operator -->|"creates"| server-a2-pod
        operator -->|"creates"| server-a2-svc
        operator -->|"creates"| server-a2-httproute
        operator -->|"creates"| server-a2-reg

        %% Kuadrant relationships
        kuadrant-op -.->|"configures"| authorino
        kuadrant-op -.->|"creates WasmPlugin"| team-a-envoy

        %% Data path
        team-a-envoy -->|"ext_proc"| team-a-mcp-gw
        team-a-envoy -->|"routes to"| server-a1-svc
        team-a-envoy -->|"routes to"| server-a2-svc

        %% Auth flow
        team-a-envoy -.->|"Wasm plugin calls"| authorino
        authorino -.->|"JWKS (in-cluster)"| keycloak

        %% Vault credential exchange
        authorino -.->|"JWT login +<br/>secret read"| vault-pod
        vault-jwt-auth -.->|"validates JWT via"| keycloak
    end

    %% External access
    client["Client / mcp-client.sh"]
    client -->|"team-a gateway"| team-a-envoy

    %% Keycloak clients
    subgraph kc-clients["Keycloak Clients"]
        kc-gw-client["mcp-gateway<br/>(confidential, client_credentials)"]
        kc-cli-client["mcp-cli<br/>(public, device auth +<br/>direct access grant)"]
        kc-inspector-client["mcp-inspector<br/>(public, auth code + PKCE)"]
    end

    subgraph kc-users["Users & Groups"]
        alice["alice → developers"]
        bob["bob → ops"]
        carol["carol → developers, ops"]
    end

    classDef ns fill:none,stroke:#666,stroke-width:2px,stroke-dasharray:5 5
    classDef pod fill:#e8f4fd,stroke:#2196F3,stroke-width:1px
    classDef svc fill:#fff3e0,stroke:#FF9800,stroke-width:1px
    classDef cr fill:#e8f5e9,stroke:#4CAF50,stroke-width:1px
    classDef storage fill:#fce4ec,stroke:#E91E63,stroke-width:1px
    classDef external fill:#f3e5f5,stroke:#9C27B0,stroke-width:2px
    classDef auth fill:#fff9c4,stroke:#FBC02D,stroke-width:1px

    class catalog-system,istio-system,mcp-system,team-a,operator-system,metallb-system,keycloak-ns,kuadrant-system,cert-manager-ns,vault-ns ns
    class team-a-envoy,catalog-api,team-a-mcp-gw,mcp-ctrl,server-a1-pod,server-a2-pod,keycloak,operator,istiod,sail-operator,metallb,authorino,kuadrant-op,limitador,vault-pod pod
    class server-a1-svc,server-a2-svc,kc-svc svc
    class server-a1-httproute,server-a1-reg,server-a2-httproute,server-a2-reg,team-a-gw,team-a-gw-ext,team-a-config-secret,selfsigned-issuer,ca-cert,ca-issuer,vault-jwt-auth,vault-role,vault-policy cr
    class ca-secret storage
    class postgres,catalog-cm,realm-cm,vault-secrets storage
    class client external
    class kc-gw-client,kc-cli-client,kc-inspector-client,alice,bob,carol,kc-clients,kc-users auth
