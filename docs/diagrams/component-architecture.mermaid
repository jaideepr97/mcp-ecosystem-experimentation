%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#e8f4fd', 'primaryBorderColor': '#2196F3', 'secondaryColor': '#fff3e0', 'tertiaryColor': '#e8f5e9' } } }%%

graph TB
    subgraph kind["Kind Cluster (mcp-gateway)"]

        subgraph catalog-system["catalog-system namespace"]
            postgres[(PostgreSQL)]
            catalog-cm[/"ConfigMap<br/>mcp-catalog-sources"/]
            catalog-api["Catalog API<br/>(REST :8080)"]
            catalog-api --> postgres
            catalog-api --> catalog-cm
        end

        subgraph cert-manager-ns["cert-manager namespace"]
            selfsigned-issuer["ClusterIssuer<br/>selfsigned-issuer"]
            ca-cert["Certificate<br/>mcp-ca-cert (isCA)"]
            ca-secret["Secret<br/>mcp-ca-secret"]
            ca-issuer["ClusterIssuer<br/>mcp-ca-issuer"]
            selfsigned-issuer -->|signs| ca-cert
            ca-cert -->|stored in| ca-secret
            ca-secret -->|referenced by| ca-issuer
        end

        subgraph gateway-system["gateway-system namespace"]
            envoy["Envoy Proxy<br/>(mcp-gateway-istio<br/>:8080/:8002/:8443/:8445)"]
            gateway-res["Gateway Resource"]
            ref-grant["ReferenceGrant"]
            ef-extproc["EnvoyFilter<br/>(ext_proc → Router)"]
            gw-authpolicy["AuthPolicy<br/>(mcp-auth-policy)<br/>JWT auth + 401 response"]
            tls-policy["TLSPolicy<br/>(mcp-gateway-tls)"]
            gw-cert-mcp["Certificate<br/>mcp-gateway-mcp-https"]
            gw-cert-kc["Certificate<br/>mcp-gateway-keycloak-https"]
            nodeport-gw["NodePort Service<br/>30080→8080 (MCP HTTP)<br/>30089→8002 (KC HTTP)<br/>30443→8443 (MCP HTTPS)<br/>30445→8445 (KC HTTPS)"]
            nodeport-gw --> envoy
            tls-policy -->|creates| gw-cert-mcp
            tls-policy -->|creates| gw-cert-kc
        end

        subgraph kuadrant-system["kuadrant-system namespace"]
            authorino["Authorino<br/>(auth engine)"]
            kuadrant-op["Kuadrant Operator"]
            limitador["Limitador<br/>(rate limiting)"]
        end

        subgraph keycloak-ns["keycloak namespace"]
            keycloak["Keycloak 26.3<br/>(OIDC provider :8080)"]
            realm-cm[/"ConfigMap<br/>realm-import"/]
            kc-svc["Service<br/>:80 → :8080"]
            kc-httproute["HTTPRoute<br/>(OAuth discovery rewrite)"]
            kc-svc --> keycloak
            keycloak --> realm-cm
        end

        subgraph istio-system["istio-system namespace"]
            istiod["istiod<br/>(Gateway API controller)"]
        end

        subgraph mcp-system["mcp-system namespace"]
            mcp-gw-pod["mcp-gateway pod<br/>(broker + router)"]
            mcp-ctrl["mcp-controller pod"]
            mcp-gw-ext["MCPGatewayExtension"]
            httproute-gw["HTTPRoute<br/>(mcp-gateway-route)"]
            config-secret["Secret (config)"]
        end

        subgraph vault-ns["vault namespace"]
            vault-pod["Vault<br/>(dev mode :8200)"]
            vault-jwt-auth["JWT Auth Method<br/>(Keycloak JWKS)"]
            vault-role["Role: authorino<br/>(aud: mcp-gateway)"]
            vault-policy["Policy: authorino<br/>(read secret/data/mcp-gateway/*)"]
            vault-secrets[("Per-user secrets<br/>secret/mcp-gateway/{sub}")]
            vault-pod --- vault-jwt-auth
            vault-pod --- vault-secrets
        end

        subgraph mcp-test["mcp-test namespace"]
            launcher["MCP Launcher<br/>(catalog UI + deployer :8080)"]
            launcher-rbac["RBAC<br/>(SA + ClusterRole + CRB)"]
            mcpserver-cr1["MCPServer CR<br/>test-server1<br/>(gateway-ref annotation)"]
            mcpserver-cr2["MCPServer CR<br/>test-server2<br/>(gateway-ref annotation)"]
            mcpserver-cr3["MCPServer CR<br/>github<br/>(gateway-ref +<br/>credential-ref annotations)"]
            server1-pod["test-server1 pod<br/>(MCP server :9090)"]
            server1-svc["test-server1 Service"]
            server1-httproute["HTTPRoute<br/>(test-server1)"]
            server1-reg["MCPServerRegistration<br/>(test-server1)"]
            server1-authpolicy["AuthPolicy<br/>(server1-auth-policy)<br/>developers→greet, ops→add_tool"]
            server2-pod["test-server2 pod<br/>(MCP server :9090)"]
            server2-svc["test-server2 Service"]
            server2-httproute["HTTPRoute<br/>(test-server2)"]
            server2-reg["MCPServerRegistration<br/>(test-server2)"]
            server2-authpolicy["AuthPolicy<br/>(server2-auth-policy)<br/>developers→set_time, ops→auth1234+set_time"]
            github-pod["github pod<br/>(GitHub MCP server :8082)"]
            github-svc["github Service"]
            github-httproute["HTTPRoute<br/>(github)"]
            github-reg["MCPServerRegistration<br/>(github, 23 tools)"]
            github-authpolicy["AuthPolicy<br/>(github-auth-policy)<br/>Vault token exchange"]
            github-cred["Secret<br/>github-broker-credential"]
            nodeport-launcher["NodePort Service<br/>30472"]
            nodeport-launcher --> launcher
            server1-svc --> server1-pod
            server2-svc --> server2-pod
            github-svc --> github-pod
        end

        subgraph operator-system["mcp-lifecycle-operator-system namespace"]
            operator["Lifecycle Operator<br/>(main + gateway reconciler)"]
        end

        subgraph metallb-system["metallb-system namespace"]
            metallb["MetalLB"]
        end

        %% Control plane relationships
        istiod -.->|"programs via xDS"| envoy
        operator -->|"creates"| server1-pod
        operator -->|"creates"| server1-svc
        operator -->|"creates"| server1-httproute
        operator -->|"creates"| server1-reg
        operator -->|"creates"| server2-pod
        operator -->|"creates"| server2-svc
        operator -->|"creates"| server2-httproute
        operator -->|"creates"| server2-reg
        operator -.->|"watches"| mcpserver-cr1
        operator -.->|"watches"| mcpserver-cr2
        operator -.->|"watches"| mcpserver-cr3
        operator -->|"creates"| github-pod
        operator -->|"creates"| github-svc
        operator -->|"creates"| github-httproute
        operator -->|"creates"| github-reg

        %% TLS relationships
        ca-issuer -->|signs| gw-cert-mcp
        ca-issuer -->|signs| gw-cert-kc
        tls-policy -.->|"targets"| gateway-res

        %% Kuadrant relationships
        kuadrant-op -.->|"configures"| authorino
        kuadrant-op -.->|"creates WasmPlugin"| envoy

        %% Data path
        envoy -->|"ext_proc"| mcp-gw-pod
        envoy -->|"routes to"| server1-svc
        envoy -->|"routes to"| server2-svc
        envoy -->|"routes to"| github-svc
        envoy -->|"routes to (:8002)"| kc-svc

        %% Auth flow
        envoy -.->|"Wasm plugin calls"| authorino
        authorino -.->|"JWKS (in-cluster)"| keycloak

        %% Vault credential exchange
        authorino -.->|"JWT login +<br/>secret read"| vault-pod
        vault-jwt-auth -.->|"validates JWT via"| keycloak

        %% Launcher flow
        launcher -->|"reads catalog"| catalog-api
        launcher -->|"creates"| mcpserver-cr1

        %% Gateway registration
        mcp-ctrl -.->|"watches"| server1-reg
        mcp-ctrl -.->|"watches"| server2-reg
        mcp-ctrl -.->|"watches"| github-reg
    end

    %% External access
    client["Client / mcp-client.sh"]
    client -->|":8001 (MCP HTTP)"| nodeport-gw
    client -->|":8443 (MCP HTTPS)"| nodeport-gw
    client -->|":8002 (KC HTTP)"| nodeport-gw
    client -->|":8445 (KC HTTPS)"| nodeport-gw
    client -->|":8004"| nodeport-launcher

    %% Keycloak clients
    subgraph kc-clients["Keycloak Clients"]
        kc-gw-client["mcp-gateway<br/>(confidential, client_credentials)"]
        kc-cli-client["mcp-cli<br/>(public, device auth +<br/>direct access grant)"]
        kc-inspector-client["mcp-inspector<br/>(public, auth code + PKCE)"]
    end

    subgraph kc-users["Users & Groups"]
        alice["alice → developers"]
        bob["bob → ops"]
        carol["carol → developers, ops"]
    end

    classDef ns fill:none,stroke:#666,stroke-width:2px,stroke-dasharray:5 5
    classDef pod fill:#e8f4fd,stroke:#2196F3,stroke-width:1px
    classDef svc fill:#fff3e0,stroke:#FF9800,stroke-width:1px
    classDef cr fill:#e8f5e9,stroke:#4CAF50,stroke-width:1px
    classDef storage fill:#fce4ec,stroke:#E91E63,stroke-width:1px
    classDef external fill:#f3e5f5,stroke:#9C27B0,stroke-width:2px
    classDef auth fill:#fff9c4,stroke:#FBC02D,stroke-width:1px

    class catalog-system,gateway-system,istio-system,mcp-system,mcp-test,operator-system,metallb-system,keycloak-ns,kuadrant-system,cert-manager-ns,vault-ns ns
    class envoy,catalog-api,mcp-gw-pod,mcp-ctrl,launcher,server1-pod,server2-pod,github-pod,keycloak,operator,istiod,metallb,authorino,kuadrant-op,limitador,vault-pod pod
    class nodeport-gw,nodeport-launcher,server1-svc,server2-svc,github-svc,kc-svc svc
    class mcpserver-cr1,mcpserver-cr2,mcpserver-cr3,server1-httproute,server1-reg,server2-httproute,server2-reg,github-httproute,github-reg,gateway-res,ref-grant,ef-extproc,mcp-gw-ext,httproute-gw,config-secret,launcher-rbac,kc-httproute,tls-policy,gw-cert-mcp,gw-cert-kc,selfsigned-issuer,ca-cert,ca-issuer,vault-jwt-auth,vault-role,vault-policy cr
    class ca-secret,github-cred storage
    class postgres,catalog-cm,realm-cm,vault-secrets storage
    class client external
    class kc-gw-client,kc-cli-client,kc-inspector-client,alice,bob,carol,kc-clients,kc-users,gw-authpolicy,server1-authpolicy,server2-authpolicy,github-authpolicy auth
